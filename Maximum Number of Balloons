public class Solution {
    public static int maxNumberOfBalloons(String text) {
        // Step 1: Frequency array to count occurrences of all 26 lowercase English letters
        int[] counts = new int[26];
        
        // Count each character in the input string
        for (char c : text.toCharArray()) {
            counts[c - 'a']++;
        }
        
        // Step 2: Extract counts for the specific letters needed for "balloon"
        int bCount = counts['b' - 'a'];
        int aCount = counts['a' - 'a'];
        int lCount = counts['l' - 'a'] / 2; // Divided by 2 because each "balloon" needs 2 'l's
        int oCount = counts['o' - 'a'] / 2; // Divided by 2 because each "balloon" needs 2 'o's
        int nCount = counts['n' - 'a'];
        
        // Step 3: Find the bottleneck (the minimum number of complete sets we can make)
        int maxInstances = bCount;
        if (aCount < maxInstances) maxInstances = aCount;
        if (lCount < maxInstances) maxInstances = lCount;
        if (oCount < maxInstances) maxInstances = oCount;
        if (nCount < maxInstances) maxInstances = nCount;
        
        return maxInstances;
    }

    // Main method to quickly test the sample inputs
    public static void main(String[] args) {
        System.out.println(maxNumberOfBalloons("nlaebolko"));       // Output: 1
        System.out.println(maxNumberOfBalloons("loonbalxballpoon")); // Output: 2
        System.out.println(maxNumberOfBalloons("leetcode"));         // Output: 0
    }
}
