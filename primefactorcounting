import java.util.*;
public class primefactorcount{
    public static void main(String[]args){
    Scanner sc = new Scanner(System.in);
    int l = sc.nextInt();
    int r = sc.nextInt();
    int p = sc.nextInt();
    
    int toatalOcccurences = getCount (l , r , p);

    System.out.println(toatalOcccurences);
    sc.close();
}
            public static int getCount(int l, int r, int p){
                int totalCount = 0;
                for(int i=l;i<=r;i++){
                    totalCount += countfactors(i,p);
                }
                return totalCount;
            }
            public static int countfactors(int n , int p){
                int count = 0;
                while(n>0 && n%p == 0){
                    count++;
                    n = n/p;
                }
                return count;
            }

}
