import java.util.*;
public class Main{
    public static void main(String []args){
        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();
        int h =1;
        int s =1;
        int r = n;
        boolean leftToRight = true;
        while(r>1){
            if(leftToRight || r%2 ==1){
                h =h+s;
            }
            r/=2;
            s*=2;
            leftToRight = !leftToRight;
        }
        System.out.println(h);
    }
}
