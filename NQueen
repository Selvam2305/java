public class NQueenSolver {
    private int N;

    public NQueenSolver(int n) {
        this.N = n;
    }

    public void solve() {
        int[][] board = new int[N][N];
        if (solveNQueen(board, 0)) {
            printBoard(board);
        } else {
            System.out.println("No solution exists for " + N + " queens.");
        }
    }

    // The core recursive function
    private boolean solveNQueen(int[][] board, int row) {
        // Base Case: If all queens are placed, we are done!
        if (row >= N) {
            return true;
        }

        // Try placing a queen in all columns of the current 'row'
        for (int col = 0; col < N; col++) {
            if (isSafe(board, row, col)) {
                // Place the queen
                board[row][col] = 1;

                // Move to the next row
                if (solveNQueen(board, row + 1)) {
                    return true; 
                }

                // BACKTRACK: If placing queen here doesn't lead to a solution, remove it
                board[row][col] = 0;
            }
        }

        // If the queen cannot be placed in any column of this row, return false
        return false;
    }

    // Helper method to check if it's safe to place a queen at board[row][col]
    private boolean isSafe(int[][] board, int row, int col) {
        int i, j;

        // 1. Check the vertical column straight up
        for (i = 0; i < row; i++) {
            if (board[i][col] == 1) return false;
        }

        // 2. Check the top-left diagonal
        for (i = row, j = col; i >= 0 && j >= 0; i--, j--) {
            if (board[i][j] == 1) return false;
        }

        // 3. Check the top-right diagonal
        for (i = row, j = col; i >= 0 && j < N; i--, j++) {
            if (board[i][j] == 1) return false;
        }

        return true;
    }

    private void printBoard(int[][] board) {
        for (int i = 0; i < N; i++) {
            for (int j = 0; j < N; j++) {
                System.out.print(board[i][j] == 1 ? " Q " : " . ");
            }
            System.out.println();
        }
    }

    public static void main(String[] args) {
        int n = 4; // You can change this to 8 for the classic 8-Queens puzzle
        NQueenSolver solver = new NQueenSolver(n);
        solver.solve();
    }
}
}
